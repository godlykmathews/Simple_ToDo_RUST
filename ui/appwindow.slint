import { ScrollView } from "std-widgets.slint";

export struct TodoItem {
    id: int,
    title: string,
    completed: bool,
}

component CustomCheckBox inherits Rectangle {
    in property <bool> checked;
    callback toggled(bool);

    width: 24px;
    height: 24px;
    border-radius: 8px;
    border-width: 2px;
    border-color: checked ? #4f46e5 : #cbd5e1;
    background: checked ? #4f46e5 : #ffffff;

    animate background, border-color { duration: 150ms; easing: ease-in-out; }

    if checked : Text {
        text: "✓";
        color: #ffffff;
        font-size: 14px;
        font-weight: 900;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.toggled(!root.checked);
        }
    }
}

component DeleteButton inherits Rectangle {
    callback clicked;
    
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: touch.has-hover ? #fee2e2 : transparent;
    
    animate background { duration: 150ms; }

    Text {
        text: "✕";
        color: touch.has-hover ? #ef4444 : #94a3b8;
        font-size: 14px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: 150ms; }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component TaskInput inherits Rectangle {
    in-out property <string> text;
    callback accepted(string);

    height: 48px;
    min-width: 180px;
    background: #ffffff;
    border-width: 2px;
    border-color: input.has-focus ? #4f46e5 : #e2e8f0;
    border-radius: 12px;
    clip: true;
    forward-focus: input;
    drop-shadow-color: #0000000a;
    drop-shadow-blur: 8px;
    drop-shadow-offset-y: 2px;
    
    animate border-color { duration: 150ms; }

    Text {
        x: 16px;
        width: parent.width - 32px;
        height: parent.height;
        text: root.text == "" ? "What needs to be done?" : "";
        color: #94a3b8;
        font-size: 16px;
        vertical-alignment: center;
    }

    input := TextInput {
        x: 16px;
        width: parent.width - 32px;
        height: parent.height;
        text <=> root.text;
        color: #0f172a;
        selection-background-color: #4f46e5;
        selection-foreground-color: #ffffff;
        font-size: 16px;
        single-line: true;
        vertical-alignment: center;
        accepted => {
            root.accepted(self.text);
        }
    }
}

component ActionButton inherits Rectangle {
    in property <string> text;
    callback clicked;

    min-width: max(80px, label.preferred-width + 32px);
    height: 48px;
    border-radius: 12px;
    background: touch.pressed ? #3730a3 : (touch.has-hover ? #4338ca : #4f46e5);
    
    drop-shadow-color: #4f46e540;
    drop-shadow-blur: 8px;
    drop-shadow-offset-y: 4px;

    animate background { duration: 150ms; }

    label := Text {
        text: root.text;
        color: #ffffff;
        font-size: 15px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component TaskRow inherits Rectangle {
    in property <TodoItem> task;
    callback set-completed(int, bool);
    callback delete-task(int);

    height: 56px;
    border-radius: 12px;
    background: task.completed ? #f8fafc : #ffffff;
    border-width: 1px;
    border-color: task.completed ? #e2e8f0 : #e2e8f0;
    
    drop-shadow-color: #00000005;
    drop-shadow-blur: 4px;
    drop-shadow-offset-y: 2px;

    animate background, border-color { duration: 150ms; }

    CustomCheckBox {
        x: 16px;
        y: (parent.height - self.height) / 2;
        checked: task.completed;
        toggled(checked) => {
            root.set-completed(task.id, checked);
        }
    }

    Text {
        x: 56px;
        width: parent.width - self.x - 48px;
        height: parent.height;
        text: task.title;
        color: task.completed ? #94a3b8 : #0f172a;
        font-size: 16px;
        font-weight: 500;
        vertical-alignment: center;
        overflow: elide;
        animate color { duration: 150ms; }
    }

    DeleteButton {
        x: parent.width - self.width - 12px;
        y: (parent.height - self.height) / 2;
        clicked => {
            root.delete-task(task.id);
        }
    }
}

export component AppWindow inherits Window {
    title: "SRUSTDO";
    width: 580px;
    height: 680px;
    background: #f1f5f9;
    default-font-family: "Inter, Roboto, sans-serif";

    in property <[TodoItem]> tasks;
    in-out property <string> new-task-text;
    in property <string> status-message;

    callback add-task(string);
    callback set-completed(int, bool);
    callback delete-task(int);

    VerticalLayout {
        padding: 32px;
        spacing: 24px;

        Text {
            text: "My Tasks";
            font-size: 36px;
            font-weight: 800;
            color: #0f172a;
        }

        HorizontalLayout {
            height: 48px;
            spacing: 12px;

            TaskInput {
                text <=> root.new-task-text;
                horizontal-stretch: 1;
                accepted(value) => {
                    root.add-task(value);
                }
            }

            ActionButton {
                text: "Add Task";
                clicked => {
                    root.add-task(root.new-task-text);
                }
            }
        }

        if root.status-message != "" : Rectangle {
            background: #fef2f2;
            border-radius: 8px;
            border-width: 1px;
            border-color: #fecaca;
            height: msg.preferred-height + 24px;
            
            msg := Text {
                x: 12px;
                width: parent.width - 24px;
                y: 12px;
                text: root.status-message;
                color: #ef4444;
                font-size: 14px;
                font-weight: 500;
                wrap: word-wrap;
            }
        }

        Rectangle {
            background: transparent;
            vertical-stretch: 1;

            if root.tasks.length == 0 : VerticalLayout {
                alignment: center;
                spacing: 16px;
                
                Text {
                    text: "✨";
                    font-size: 48px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "You're all caught up!";
                    color: #64748b;
                    font-size: 18px;
                    font-weight: 500;
                    horizontal-alignment: center;
                }
            }

            ScrollView {
                width: 100%;
                height: 100%;
                
                VerticalLayout {
                    padding-bottom: 32px;
                    spacing: 12px;

                    for task in root.tasks : TaskRow {
                        task: task;
                        set-completed(id, completed) => {
                            root.set-completed(id, completed);
                        }
                        delete-task(id) => {
                            root.delete-task(id);
                        }
                    }
                }
            }
        }
    }
}
